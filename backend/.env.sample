# Local Docker/Postgres example
DATABASE_URL="postgresql://admin:password@localhost:5432/penalty_system?schema=public"
# Recommended for Neon production: use the non-pooler direct URL for Prisma CLI tasks
DIRECT_URL="postgresql://admin:password@localhost:5432/penalty_system?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
SUPERADMIN_EMAIL="superadmin@iitk.ac.in"
# Optional: seed multiple superadmins at once
# SUPERADMIN_EMAILS="superadmin1@iitk.ac.in,superadmin2@iitk.ac.in"

# Recommended production mail setup: SMTP with Resend or Postmark
# EMAIL_PROVIDER=smtp
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="resend"
SMTP_PASS="re_xxxxxxxxxxxxxxxxx"
SMTP_FROM_NAME="IITK Election Commission"
SMTP_FROM_EMAIL="no-reply@your-domain.com"

# Local/dev alternative: Gmail SMTP with an app password
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-16-character-app-password"
# SMTP_FROM_EMAIL="your-email@gmail.com"

# EmailJS provider configuration
# Keep OTP generation and verification on the backend even when using EmailJS.
# EMAIL_PROVIDER="emailjs"
# EMAILJS_SERVICE_ID="service_xxxxx"
# EMAILJS_TEMPLATE_ID="template_generic"
# EMAILJS_TEMPLATE_ID_OTP="template_otp"
# EMAILJS_TEMPLATE_ID_PENALTY="template_penalty"
# EMAILJS_PUBLIC_KEY="public_xxxxx"
# EMAILJS_PRIVATE_KEY="private_xxxxx"
# EMAILJS_FROM_NAME="IITK Election Commission"
# EMAILJS_FROM_EMAIL="no-reply@your-domain.com"

FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,https://your-frontend-domain.web.app,https://your-frontend-domain.firebaseapp.com"
PORT=5000

# Google Sheets integration
# Preferred: keep the JSON file only on your machine in an ignored folder
GOOGLE_APPLICATION_CREDENTIALS="./secrets/google-service-account.json"
# Recommended for production platforms such as Render: paste the entire JSON inline
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# Optional: seed students from a local JSON export when needed
# STUDENT_SEED_PATH="C:/path/to/students.json"
